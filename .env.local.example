# ─────────────────────────────────────────
# Event Radar — Environment Variables
# Copy this file to .env.local and fill in
# your values from the Supabase dashboard.
# ─────────────────────────────────────────

# Supabase — Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Only needed for admin/server-side operations (never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─────────────────────────────────────────
# Supabase Storage setup (run once in Supabase dashboard):
#
#   1. Go to Storage → Create bucket
#   2. Name: event-images
#   3. Public bucket: YES
#   4. Allowed MIME types: image/jpeg, image/png, image/webp
#   5. Max file size: 10MB
#
# ─────────────────────────────────────────
# Google OAuth setup (for sign-in with Google):
#
#   1. Supabase dashboard → Authentication → Providers → Google
#   2. Add your Google OAuth client ID and secret
#   3. Add redirect URL: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
#
# ─────────────────────────────────────────
