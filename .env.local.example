# ─────────────────────────────────────────
# Event Radar — Environment Variables
# Copy this file to .env.local and fill in
# your values from the Supabase dashboard.
# ─────────────────────────────────────────

# Supabase — Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Only needed for admin/server-side operations (never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ─────────────────────────────────────────
# Supabase Storage setup (run once in Supabase dashboard):
#
#   1. Go to Storage → Create bucket
#   2. Name: event-images
#   3. Public bucket: YES
#   4. Allowed MIME types: image/jpeg, image/png, image/webp
#   5. Max file size: 10MB
#
# ─────────────────────────────────────────
# Google OAuth setup (for sign-in with Google):
#
#   1. Supabase dashboard → Authentication → Providers → Google
#   2. Add your Google OAuth client ID and secret
#   3. Add redirect URL: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
#
# ─────────────────────────────────────────

# ─────────────────────────────────────────
# Ticketmaster Affiliate (via Impact platform)
#
# How to get your affiliate ID:
#   1. Sign up at https://app.impact.com
#   2. Search for "Ticketmaster" in the marketplace
#   3. Apply and get approved (usually 1-3 days)
#   4. Copy your Publisher ID
#   5. Paste it below and add the same variable in Vercel
#
# When set: ticket links to ticketmaster.no/no will include
# ?camefrom=YOUR_ID so Impact can track clicks and pay commission.
# When NOT set: ticket links work normally with no tracking.
# ─────────────────────────────────────────
# NEXT_PUBLIC_TM_AFFILIATE_ID=YOUR_PUBLISHER_ID
